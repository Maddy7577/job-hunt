# ── Mock / dev mode ───────────────────────────────────────────────────
# APIFY_MOCK=true means the app uses fake job data (no Apify credits consumed).
# Set to false (and fill in APIFY_API_TOKEN below) when ready to use real scraping.
APIFY_MOCK=true

# ── Apify (uncomment when ready) ──────────────────────────────────────
# APIFY_API_TOKEN=apify_api_xxxxxxxxxxxx

# ── Anthropic / Claude API (uncomment when ready) ─────────────────────
# Scoring currently uses sentence-transformers (free, local).
# Uncomment below to upgrade to Claude-based rationale.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── Flask ─────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change_me
UPLOAD_FOLDER=uploads
DATABASE_URL=sqlite:///jobhunt.db
MAX_RESULTS_DEFAULT=50

# ── AutoHunt Gmail Digest ──────────────────────────────────────────────
# One-time setup: create a Google App Password at myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account).
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Free-tier key from Google AI Studio: aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
# Who receives the digest emails (leave blank to default to GMAIL_ADDRESS)
NOTIFY_EMAIL=you@gmail.com
